---
import { Image } from "astro:assets";

import type { GameData } from "./games.ts";
import type { ImageMetadata } from "astro";

interface Props {
  gameData: GameData;
  isDisplayYear: boolean;
}

const matchedImages = import.meta.glob<{ default: ImageMetadata }>("../assets/*", { eager: true });
const images: Record<string, ImageMetadata> = {};
for (const [key, value] of Object.entries(matchedImages)) {
  const fileName = key.split("/").pop()!;
  images[fileName] = value.default;
}

const { gameData, isDisplayYear } = Astro.props;
---

<div id={gameData.id} class="flex items-center justify-center">
  <div
    class="group flex aspect-square w-full flex-col overflow-hidden rounded-lg border border-black bg-white p-1 shadow-lg sm:w-3xs"
  >
    <div class="relative flex h-[56.25%] w-full items-center justify-center overflow-hidden bg-gray-100">
      {
        gameData.imageSrc ? (
          <Image src={images[gameData.imageSrc]} alt={gameData.title} class="h-full w-full object-contain" />
        ) : (
          <span class="text-sm font-bold text-gray-400">NO IMAGE</span>
        )
      }

      {isDisplayYear && <span class="absolute top-2 left-2 rounded-full bg-white px-2 py-1">{gameData.year}</span>}
    </div>
    <div class="flex h-[43.75%] flex-col justify-between p-2">
      <div>
        <p class="line-clamp-1 font-bold">
          {gameData.title}
        </p>
        <p class="line-clamp-2 text-xs">
          {gameData.description}
        </p>
      </div>
      {
        gameData.atwikiUrl && (
          <a
            href={gameData.atwikiUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-fit items-center justify-center rounded-full bg-black px-2 py-1 text-xs text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2"
          >
            &#8599;@wiki
          </a>
        )
      }
    </div>
  </div>
</div>
