---
import Layout from "../../../layouts/Layout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <section class="container m-auto px-2 md:w-[80%]">
    <h2 class="my-4 text-2xl font-bold md:text-3xl">{title}</h2>
    <slot />
  </section>
</Layout>
