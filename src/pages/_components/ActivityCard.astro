---
interface Props {
  title: string;
  description: string;
  activityExamplesText: string;
  class?: string;
}

const { title, description, activityExamplesText, class: className } = Astro.props;
---

<div
  class:list={[
    "rounded-xl px-4 pt-2 pb-4 shadow-lg/25 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2",
    className,
  ]}
>
  <h3 class="my-2 text-xl font-bold md:text-2xl">{title}</h3>
  <p class="mt-2 text-sm whitespace-pre-line text-black md:text-base">{description}</p>
  <p class="mt-1 text-sm font-bold text-black md:text-base">{activityExamplesText}</p>
</div>
