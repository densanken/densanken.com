---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  class:list={[
    "flex w-fit items-center rounded-full px-6 py-3 font-bold shadow-md transition-transform duration-100",
    "focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2",
    "hover:-translate-y-1 active:translate-y-0.5",
    className,
  ]}
  href={href}><slot /></a
>
